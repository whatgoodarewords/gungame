<installer-gui-script minSpecVersion="1">
    <title>KTX-Software</title>
    <welcome file="Welcome.rtf"/>
    <readme file="ReadMe.rtf"/>
    <license file="License.rtf"/>
    <domains enable_localSystem="true"/>
    <options allow-external-scripts="no" customize="allow" rootVolumeOnly="true"/>
    <choices-outline>
        <line choice="devChoice"/>
        <line choice="jniChoice"/>
        <line choice="libraryChoice"/>
        <line choice="toolsChoice"/>
    </choices-outline>
    <choice id="devChoice" title="Development" start_selected="false" start_enabled="true" start_visible="true" description="Additional resources for development (header files and documentation)." selected="my.choice.selected &amp;&amp; choices['libraryChoice'].selected">
        <pkg-ref id="com.khronos.ktx.dev"/>
    </choice>
    <pkg-ref id="com.khronos.ktx.dev" version="4.4.2" installKBytes="125" auth="Admin" onConclusion="None" updateKBytes="0">#KTX-Software-4.4.2-Darwin-arm64-dev.pkg</pkg-ref>
    <choice id="jniChoice" title="Java wrapper" start_selected="false" start_enabled="true" start_visible="true" description="Java wrapper and native interface for KTX library." selected="my.choice.selected &amp;&amp; choices['libraryChoice'].selected">
        <pkg-ref id="com.khronos.ktx.jni"/>
    </choice>
    <pkg-ref id="com.khronos.ktx.jni" version="4.4.2" installKBytes="125" auth="Admin" onConclusion="None" updateKBytes="0">#KTX-Software-4.4.2-Darwin-arm64-jni.pkg</pkg-ref>
    <choice id="libraryChoice" title="Library" start_selected="true" start_enabled="false" start_visible="true" description="Main KTX library." selected="my.choice.selected || choices['devChoice'].selected || choices['toolsChoice'].selected || choices['jniChoice'].selected">
        <pkg-ref id="com.khronos.ktx.library"/>
    </choice>
    <pkg-ref id="com.khronos.ktx.library" version="4.4.2" installKBytes="2438" auth="Admin" onConclusion="None" updateKBytes="0">#KTX-Software-4.4.2-Darwin-arm64-library.pkg</pkg-ref>
    <choice id="toolsChoice" title="Command line tools" start_selected="true" start_enabled="true" start_visible="true" description="Command line tools for creating, converting and inspecting KTX files." selected="my.choice.selected &amp;&amp; choices['libraryChoice'].selected">
        <pkg-ref id="com.khronos.ktx.tools"/>
    </choice>
    <pkg-ref id="com.khronos.ktx.tools" version="4.4.2" installKBytes="12850" auth="Admin" onConclusion="None" updateKBytes="0">#KTX-Software-4.4.2-Darwin-arm64-tools.pkg</pkg-ref>
    <background file="ktx_logo_190_xp.png" alignment="bottomleft" mime-type="image/png"/>
    <conclusion file="summary.html" mime-type="text/html"/>
    <pkg-ref id="com.khronos.ktx.dev">
        <bundle-version/>
    </pkg-ref>
    <pkg-ref id="com.khronos.ktx.jni">
        <bundle-version/>
    </pkg-ref>
    <pkg-ref id="com.khronos.ktx.library">
        <bundle-version/>
    </pkg-ref>
    <pkg-ref id="com.khronos.ktx.tools">
        <bundle-version/>
    </pkg-ref>
    <product version="4.4.2"/>
</installer-gui-script>